{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      ".git/**",
      ".firebase/**",
      "**/*.ps1",
      "**/node_modules/**",
      "README.md",
      "LICENSE",
      "tools/**"
    ],
    "rewrites": [
      { "source": "/", "destination": "/real-war-shooter.html" },
      { "source": "/play", "destination": "/real-war-shooter.html" }
    ],
    "headers": [
      {
        "source": "real-war-shooter.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
        ]
      }
    ]
  }
}
